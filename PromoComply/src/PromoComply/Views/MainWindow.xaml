<Window x:Class="PromoComply.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:PromoComply"
        Title="PromoComply" Height="768" Width="1280" WindowStartupLocation="CenterScreen">
    <Grid Background="{StaticResource DarkBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Background="{StaticResource PrimaryBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="PromoComply" Style="{StaticResource H2TextBlock}" Foreground="{StaticResource AccentBrush}" Margin="16,0,0,4"/>
                <TextBlock Text="Pharma Promotional Compliance" Style="{StaticResource SecondaryTextBlock}" Margin="16,0,0,20" Foreground="{StaticResource TextSecondaryBrush}"/>

                <Button x:Name="DashboardBtn" Content="Dashboard" Style="{StaticResource SidebarButton}" Click="DashboardBtn_Click"/>
                <Button x:Name="DocumentsBtn" Content="Documents" Style="{StaticResource SidebarButton}" Click="DocumentsBtn_Click"/>
                <Button x:Name="ReviewBtn" Content="Review" Style="{StaticResource SidebarButton}" Click="ReviewBtn_Click"/>
                <Button x:Name="ReportsBtn" Content="Reports" Style="{StaticResource SidebarButton}" Click="ReportsBtn_Click"/>
            </StackPanel>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="60"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Top Bar -->
            <Border Grid.Row="0" Background="{StaticResource LightBackgroundBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="20,0">
                    <TextBlock Text="PromoComply" Style="{StaticResource H3TextBlock}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ProgressText" Text="{Binding AnalyzeProgressText}" Style="{StaticResource BodyTextBlock}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <!-- Content Area -->
            <ContentControl x:Name="ContentControl" Grid.Row="1" Margin="0" Foreground="{StaticResource TextPrimaryBrush}"/>
        </Grid>
    </Grid>
</Window>
