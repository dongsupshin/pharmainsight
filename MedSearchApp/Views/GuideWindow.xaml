<Window x:Class="MedSearchApp.Views.GuideWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PharmaInsight — How to Use"
        Width="540" Height="530"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="#F5F5F5"
        ShowInTaskbar="False">

    <Grid Margin="24,20,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="🏥" FontSize="22" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock Text="PharmaInsight — How to Use"
                           FontSize="17" FontWeight="Bold" Foreground="#1A1A2E"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock Text="Korean hospital &amp; pharmacy lookup tool  ·  Powered by HIRA data"
                       FontSize="12" Foreground="#888"/>
        </StackPanel>

        <!-- ── Steps ── -->
        <StackPanel Grid.Row="1" Margin="0,0,0,12">

            <!-- Step 1 -->
            <Border Background="White" CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#0078D4" CornerRadius="14" Width="28" Height="28"
                            VerticalAlignment="Top" Margin="0,2,0,0">
                        <TextBlock Text="1" Foreground="White" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Search for a hospital or pharmacy"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,3,0,0"
                                   FontSize="12" Foreground="#555"
                                   Text="Type a Korean name (e.g. 서울, 삼성, 세브란스, 약국) in the search box, then press  Search  or hit  Enter."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Step 2 -->
            <Border Background="White" CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#0078D4" CornerRadius="14" Width="28" Height="28"
                            VerticalAlignment="Top" Margin="0,2,0,0">
                        <TextBlock Text="2" Foreground="White" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Browse the results table"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,3,0,0"
                                   FontSize="12" Foreground="#555"
                                   Text="Results appear in the table showing the institution name, HIRA code, address, postal code, type, and phone number. Click any row to select it."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Step 3 -->
            <Border Background="White" CornerRadius="8" Padding="14,12" Margin="0,0,0,8"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#0078D4" CornerRadius="14" Width="28" Height="28"
                            VerticalAlignment="Top" Margin="0,2,0,0">
                        <TextBlock Text="3" Foreground="White" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Copy institution code or address"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,3,0,0"
                                   FontSize="12" Foreground="#555"
                                   Text="Select a row and use  Copy Code  to copy the HIRA institution code, or  Copy Address  to copy the full street address to clipboard."/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Step 4 -->
            <Border Background="White" CornerRadius="8" Padding="14,12"
                    BorderBrush="#E8E8E8" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="36"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Background="#0078D4" CornerRadius="14" Width="28" Height="28"
                            VerticalAlignment="Top" Margin="0,2,0,0">
                        <TextBlock Text="4" Foreground="White" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Export results as CSV"
                                   FontSize="13" FontWeight="SemiBold" Foreground="#1A1A2E"/>
                        <TextBlock TextWrapping="Wrap" Margin="0,3,0,0"
                                   FontSize="12" Foreground="#555"
                                   Text="Click  Export CSV  to save all search results as a spreadsheet (.csv). Open directly in Excel or Google Sheets."/>
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>

        <!-- ── Demo box ── -->
        <Border Grid.Row="2" Background="#EBF4FF" BorderBrush="#93C5FD"
                BorderThickness="1" CornerRadius="8" Padding="14,12" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="▶  Try the Demo"
                               FontSize="13" FontWeight="SemiBold" Foreground="#1D4ED8"/>
                    <TextBlock FontSize="12" Foreground="#3B82F6" Margin="0,3,0,0"
                               Text="Click the button to search for '서울' and instantly see real results from the built-in sample data."/>
                </StackPanel>
                <Button Grid.Column="1"
                        x:Name="BtnRunDemo"
                        Content="▶ Run Demo Search"
                        Click="BtnRunDemo_Click"
                        Background="#1D4ED8" Foreground="White"
                        BorderThickness="0" Padding="14,8" FontSize="12"
                        Cursor="Hand" Margin="12,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#1E40AF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── Close button ── -->
        <Button Grid.Row="3"
                Content="Close"
                Click="BtnClose_Click"
                HorizontalAlignment="Right"
                Background="#6C757D" Foreground="White"
                BorderThickness="0" Padding="20,8" FontSize="13"
                Cursor="Hand">
            <Button.Template>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            CornerRadius="5" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#5A6268"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Button.Template>
        </Button>

    </Grid>
</Window>
