<Window x:Class="MedSearchApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MedSearchApp.ViewModels"
        Title="{Binding WindowTitle}" Height="640" Width="1080"
        MinHeight="520" MinWidth="720"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- 기본 버튼 스타일 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#006BBF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button"
               BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#6C757D"/>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="BorderBrush" Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F0F0F0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 카드 스타일 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1"
                                      Color="#CCCCCC" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 헤더 -->
            <RowDefinition Height="Auto"/>   <!-- 검색바 -->
            <RowDefinition Height="Auto"/>   <!-- API 한도 초과 배너 -->
            <RowDefinition Height="Auto"/>   <!-- Pro 필터 / 업그레이드 CTA -->
            <RowDefinition Height="*"/>      <!-- 결과 목록 -->
            <RowDefinition Height="Auto"/>   <!-- 상세 정보 -->
            <RowDefinition Height="Auto"/>   <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- ── 헤더 ── -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 타이틀 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🏥" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding LblTitle}" FontSize="18"
                                       FontWeight="Bold" Foreground="#1A1A2E"
                                       VerticalAlignment="Center"/>
                            <!-- PRO/FREE 배지 -->
                            <Border CornerRadius="4" Padding="8,3" Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPro}" Value="True">
                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                <Setter Property="BorderBrush" Value="#F2B900"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsPro}" Value="False">
                                                <Setter Property="Background" Value="#F3F4F6"/>
                                                <Setter Property="BorderBrush" Value="#D1D5DB"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding ProBadgeText}"
                                           FontSize="10" FontWeight="Bold"
                                           Foreground="#8B5A00"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="{Binding LblSubtitle}"
                                   FontSize="11" Foreground="#666"/>
                    </StackPanel>
                </StackPanel>

                <!-- 버튼 그룹 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Guide 버튼 -->
                    <Button Content="{Binding LblGuide}"
                            Command="{Binding OpenGuideCommand}"
                            Style="{StaticResource OutlineButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                    <!-- 언어 토글 -->
                    <Button Content="{Binding LblLangToggle}"
                            Command="{Binding ToggleLanguageCommand}"
                            Style="{StaticResource OutlineButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,6,0"/>
                    <!-- 설정 -->
                    <Button Content="{Binding LblSettings}"
                            Command="{Binding OpenSettingsCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,6" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 검색바 ── -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 검색 입력 + placeholder overlay -->
                <Grid Grid.Column="0" Margin="0,0,8,0">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="10,8" BorderThickness="1"
                             BorderBrush="#DDDDDD"
                             VerticalContentAlignment="Center"
                             Background="White">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Return" Command="{Binding SearchCommand}"/>
                        </TextBox.InputBindings>
                    </TextBox>
                    <!-- Placeholder overlay -->
                    <TextBlock Text="{Binding SearchPlaceholder}"
                               IsHitTestVisible="False"
                               Foreground="#AAAAAA" FontSize="13"
                               Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <Button Grid.Column="1"
                        Content="{Binding LblSearch}"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="2"
                        Content="{Binding LblCancel}"
                        Command="{Binding SearchCancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="3"
                        Content="{Binding LblExport}"
                        Command="{Binding ExportCsvCommand}"
                        Style="{StaticResource SecondaryButton}"/>
            </Grid>
        </Border>

        <!-- ── API 한도 초과 안내 배너 ── -->
        <Border Grid.Row="2"
                Background="#FFF3CD" BorderBrush="#FBBF24" BorderThickness="1"
                CornerRadius="6" Padding="14,10" Margin="0,0,0,10"
                Visibility="{Binding IsBiznoQuotaExceeded,
                    Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="⚠" FontSize="16"
                           Foreground="#92400E" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#78350F"
                               Text="{Binding BiznoQuotaBannerTitle}"/>
                    <TextBlock FontSize="12" Foreground="#92400E" Margin="0,2,0,0"
                               Text="{Binding BiznoQuotaBannerDesc}"/>
                </StackPanel>

                <Button Grid.Column="2"
                        Content="{Binding LblSettingsForBizno}"
                        Command="{Binding OpenSettingsForBiznoCommand}"
                        Background="#D97706" Foreground="White"
                        BorderThickness="0" Padding="12,6" FontSize="12"
                        Cursor="Hand" Margin="12,0,6,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#B45309"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button Grid.Column="3"
                        Content="✕"
                        Command="{Binding DismissBiznoQuotaBannerCommand}"
                        Background="Transparent" Foreground="#92400E"
                        BorderThickness="0" Padding="6,4" FontSize="13"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FDE68A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- ── Pro 필터 바 (PRO 활성 시) / 업그레이드 CTA (Free 시) ── -->
        <Border Grid.Row="3" Margin="0,0,0,12">
            <Grid>
                <!-- Free: 업그레이드 CTA -->
                <Border Background="#FFF9E6" BorderBrush="#F2B900" BorderThickness="1"
                        CornerRadius="6" Padding="14,10"
                        Visibility="{Binding ProUpgradePromptVisible,
                            Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="★" FontSize="18" Foreground="#8B5A00"
                                   VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding LblProUpgrade}"
                                   FontSize="12" Foreground="#5A3B00"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                        <Button Grid.Column="2"
                                Content="{Binding ProUpgradeCta}"
                                Command="{Binding UpgradeToProCommand}"
                                Background="#F2B900" Foreground="#4A2F00"
                                BorderThickness="0" Padding="14,7" FontSize="12"
                                FontWeight="SemiBold" Cursor="Hand" Margin="12,0,0,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#D9A600"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <!-- Pro: 타겟 필터 -->
                <Border Style="{StaticResource Card}"
                        Visibility="{Binding IsPro,
                            Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="{Binding LblFilterTitle}"
                                   FontWeight="SemiBold" FontSize="12"
                                   VerticalAlignment="Center" Margin="0,0,14,0"
                                   Foreground="#8B5A00"/>

                        <TextBlock Grid.Column="1" Text="{Binding LblFilterGrade}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Grid.Column="2" Width="70"
                                  SelectedValue="{Binding SelectedGradeFilter}"
                                  SelectedValuePath="Content"
                                  Margin="0,0,12,0">
                            <ComboBoxItem Content="" IsSelected="True"/>
                            <ComboBoxItem Content="S"/>
                            <ComboBoxItem Content="A"/>
                            <ComboBoxItem Content="B"/>
                            <ComboBoxItem Content="C"/>
                        </ComboBox>

                        <TextBlock Grid.Column="3" Text="{Binding LblFilterType}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <ComboBox Grid.Column="4" Width="130"
                                  SelectedValue="{Binding SelectedTypeFilter}"
                                  SelectedValuePath="Content"
                                  Margin="0,0,12,0">
                            <ComboBoxItem Content=""/>
                            <ComboBoxItem Content="상급종합병원"/>
                            <ComboBoxItem Content="종합병원"/>
                            <ComboBoxItem Content="병원"/>
                            <ComboBoxItem Content="의원"/>
                            <ComboBoxItem Content="약국"/>
                        </ComboBox>

                        <TextBlock Grid.Column="5" Text="{Binding LblFilterMinDoc}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBox Grid.Column="6" Width="60" HorizontalAlignment="Left"
                                 Text="{Binding MinDoctorCount, UpdateSourceTrigger=PropertyChanged}"
                                 Padding="6,4" VerticalContentAlignment="Center"/>

                        <Button Grid.Column="7" Content="{Binding LblApplyFilter}"
                                Command="{Binding ApplyFilterCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="14,6" FontSize="12" Margin="8,0,6,0"/>
                        <Button Grid.Column="8" Content="{Binding LblClearFilter}"
                                Command="{Binding ClearFilterCommand}"
                                Style="{StaticResource OutlineButton}"
                                Padding="12,6" FontSize="12"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ── 결과 목록 ── -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="{Binding LblResultsTitle}"
                           FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

                <!-- 로딩 인디케이터 -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLoading,
                                Converter={StaticResource BoolToVisibility}}">

                    <Grid Width="40" Height="40" Margin="0,0,0,12">
                        <Ellipse Width="40" Height="40"
                                 Stroke="#E0E0E0" StrokeThickness="4"/>
                        <Path x:Name="SpinnerArc"
                              Stroke="#0078D4" StrokeThickness="4"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="20,2">
                                        <ArcSegment Point="38,20" Size="18,18"
                                                    SweepDirection="Clockwise" IsLargeArc="False"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                            </Path.RenderTransform>
                        </Path>
                    </Grid>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding LblSearching}"
                                   FontSize="14" Foreground="#555"/>
                        <TextBlock x:Name="Dot1" Text="." FontSize="14" Foreground="#555" Opacity="0"/>
                        <TextBlock x:Name="Dot2" Text="." FontSize="14" Foreground="#555" Opacity="0"/>
                        <TextBlock x:Name="Dot3" Text="." FontSize="14" Foreground="#555" Opacity="0"/>
                    </StackPanel>

                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <DoubleAnimation
                                        Storyboard.TargetName="SpinnerRotate"
                                        Storyboard.TargetProperty="Angle"
                                        From="0" To="360" Duration="0:0:0.9"/>
                                    <DoubleAnimation
                                        Storyboard.TargetName="Dot1"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1" Duration="0:0:0.2"
                                        BeginTime="0:0:0"/>
                                    <DoubleAnimation
                                        Storyboard.TargetName="Dot2"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1" Duration="0:0:0.2"
                                        BeginTime="0:0:0.3"/>
                                    <DoubleAnimation
                                        Storyboard.TargetName="Dot3"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1" Duration="0:0:0.2"
                                        BeginTime="0:0:0.6"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                </StackPanel>

                <!-- 결과 DataGrid -->
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SearchResults}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          BorderThickness="0"
                          RowBackground="White"
                          AlternatingRowBackground="#F8F9FA"
                          FontSize="12"
                          Visibility="{Binding IsLoading,
                              Converter={StaticResource InvertBoolToVisibility}}">
                    <DataGrid.Columns>

                        <DataGridTextColumn Binding="{Binding Name}"
                                            Width="180" MinWidth="120">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColName,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding InstitutionCode}"
                                            Width="130">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColCode,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding BusinessNumber}"
                                            Width="110">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColBizNo,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#888888"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding Address}"
                                            Width="*" MinWidth="180">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColAddress,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding PostalCode}"
                                            Width="70">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColPostal,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding InstitutionType}"
                                            Width="110">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColType,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>

                        <!-- ★ Pro: 추정매출등급 -->
                        <DataGridTextColumn
                            Binding="{Binding RevenueGrade}"
                            Width="70">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColGrade,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="S">
                                            <Setter Property="Foreground" Value="#B91C1C"/>
                                        </Trigger>
                                        <Trigger Property="Text" Value="A">
                                            <Setter Property="Foreground" Value="#C2410C"/>
                                        </Trigger>
                                        <Trigger Property="Text" Value="B">
                                            <Setter Property="Foreground" Value="#0369A1"/>
                                        </Trigger>
                                        <Trigger Property="Text" Value="C">
                                            <Setter Property="Foreground" Value="#4B5563"/>
                                        </Trigger>
                                        <Trigger Property="Text" Value="🔒">
                                            <Setter Property="Foreground" Value="#D97706"/>
                                            <Setter Property="FontWeight" Value="Normal"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- ★ Pro: 의사수 (마스킹 지원) -->
                        <DataGridTextColumn
                            Binding="{Binding DoctorTotalCount, Converter={StaticResource MaskedInt}}"
                            Width="60">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColDoctors,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- ★ Pro: 간호사수 (마스킹 지원) -->
                        <DataGridTextColumn
                            Binding="{Binding NurseCount, Converter={StaticResource MaskedInt}}"
                            Width="70">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColNurses,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="HorizontalAlignment" Value="Right"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding PhoneNumber}"
                                            Width="110">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColPhone,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>

                        <DataGridTextColumn Binding="{Binding DataSource}"
                                            Width="80">
                            <DataGridTextColumn.Header>
                                <TextBlock Text="{Binding DataContext.ColSource,
                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGridTextColumn.Header>
                        </DataGridTextColumn>

                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- ── 선택 항목 상세 ── -->
        <Border Grid.Row="5" Style="{StaticResource Card}" Margin="0,0,0,12"
                Visibility="{Binding SelectedItem,
                    Converter={StaticResource NullToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontWeight="Bold" FontSize="13" Margin="0,0,0,6"
                               Text="{Binding SelectedItem.Name, StringFormat='📋 {0}'}"/>
                    <WrapPanel Margin="0,0,0,6">
                        <TextBlock FontSize="12" Foreground="#444"
                                   Text="{Binding SelectedItem.InstitutionCode,
                                       StringFormat='Institution Code: {0}'}"/>
                        <TextBlock FontSize="12" Foreground="#888" Margin="16,0">|</TextBlock>
                        <TextBlock FontSize="12" Foreground="#444"
                                   Text="{Binding SelectedItem.Address,
                                       StringFormat='Address: {0}'}"/>
                        <TextBlock FontSize="12" Foreground="#888" Margin="16,0">|</TextBlock>
                        <TextBlock FontSize="12" Foreground="#444"
                                   Text="{Binding SelectedItem.PostalCode,
                                       StringFormat='Postal: {0}'}"/>
                    </WrapPanel>
                    <!-- 사업자번호 직접 입력 -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding LblBizNoLabel}" FontSize="12" Foreground="#444"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="BizNoInput"
                                 Text="{Binding SelectedBizNo, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12" Width="140" Padding="4,3"
                                 BorderBrush="#CCCCCC" VerticalContentAlignment="Center"
                                 MaxLength="12">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="000-00-00000"
                                                                       Foreground="#BBBBBB" FontSize="12"
                                                                       Margin="5,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return"
                                            Command="{Binding SaveBizNoCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Content="{Binding LblSave}"
                                Command="{Binding SaveBizNoCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="10,4" FontSize="11" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Content="{Binding LblCopyCode}"
                            Command="{Binding CopyInstitutionCodeCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,8,0"/>
                    <Button Content="{Binding LblCopyAddr}"
                            Command="{Binding CopyAddressCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,6" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── 상태바 ── -->
        <Border Grid.Row="6" Background="#E8E8E8" CornerRadius="4" Padding="12,6">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#555"/>
        </Border>
    </Grid>
</Window>
