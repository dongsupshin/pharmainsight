<Window x:Class="MedSearchApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MedSearchApp.ViewModels"
        Title="병원·약국 검색 (PharmaInsight)" Height="620" Width="1050"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Window.Resources>
        <!-- 기본 버튼 스타일 -->
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#006BBF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button"
               BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#6C757D"/>
        </Style>

        <!-- 카드 스타일 -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1"
                                      Color="#CCCCCC" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- 헤더 -->
            <RowDefinition Height="Auto"/>
            <!-- 검색바 -->
            <RowDefinition Height="Auto"/>
            <!-- API 한도 초과 배너 -->
            <RowDefinition Height="*"/>
            <!-- 결과 목록 -->
            <RowDefinition Height="Auto"/>
            <!-- 상세 정보 -->
            <RowDefinition Height="Auto"/>
            <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="🏥" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="병원·약국 검색" FontSize="18"
                                   FontWeight="Bold" Foreground="#1A1A2E"/>
                        <TextBlock Text="건강보험심사평가원 / 로컬 데이터 기반 · 요양기관코드 / 사업자번호 자동 조회 / 주소 / 우편번호"
                                   FontSize="11" Foreground="#666"/>
                    </StackPanel>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="⚙ API 키 설정"
                        Command="{Binding OpenSettingsCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Padding="12,6" FontSize="12"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- 검색바 -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14" Padding="10,8" BorderThickness="1"
                         BorderBrush="#DDDDDD" Margin="0,0,8,0"
                         VerticalContentAlignment="Center">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Style.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <VisualBrush Stretch="None" AlignmentX="Left">
                                                <VisualBrush.Visual>
                                                    <TextBlock Text="병원명 또는 약국명 입력 (예: 서울대학교병원, 온누리약국)"
                                                               Foreground="#AAAAAA" FontSize="13"
                                                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return"
                                    Command="{Binding SearchCommand}"/>
                    </TextBox.InputBindings>
                </TextBox>

                <Button Grid.Column="1"
                        Content="🔍 검색"
                        Command="{Binding SearchCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="2"
                        Content="⏹ 취소"
                        Command="{Binding SearchCancelCommand}"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0"/>

                <Button Grid.Column="3"
                        Content="📥 CSV 저장"
                        Command="{Binding ExportCsvCommand}"
                        Style="{StaticResource SecondaryButton}"/>
            </Grid>
        </Border>

        <!-- ── API 한도 초과 안내 배너 ── -->
        <Border Grid.Row="2"
                Background="#FFF3CD" BorderBrush="#FBBF24" BorderThickness="1"
                CornerRadius="6" Padding="14,10" Margin="0,0,0,10"
                Visibility="{Binding IsBiznoQuotaExceeded,
                    Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 경고 아이콘 -->
                <TextBlock Grid.Column="0" Text="⚠" FontSize="16"
                           Foreground="#92400E" VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <!-- 메시지 -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock FontSize="13" FontWeight="SemiBold" Foreground="#78350F"
                               Text="사업자번호 API 일일 한도(200건)를 초과했습니다."/>
                    <TextBlock FontSize="12" Foreground="#92400E" Margin="0,2,0,0"
                               Text="설정에서 새 API 키를 등록하면 다시 자동 조회됩니다. (bizno.net 무료 가입 후 발급)"/>
                </StackPanel>

                <!-- 설정 열기 버튼 -->
                <Button Grid.Column="2"
                        Content="⚙ API 키 설정"
                        Command="{Binding OpenSettingsForBiznoCommand}"
                        Background="#D97706" Foreground="White"
                        BorderThickness="0" Padding="12,6" FontSize="12"
                        Cursor="Hand" Margin="12,0,6,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#B45309"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 닫기 버튼 -->
                <Button Grid.Column="3"
                        Content="✕"
                        Command="{Binding DismissBiznoQuotaBannerCommand}"
                        Background="Transparent" Foreground="#92400E"
                        BorderThickness="0" Padding="6,4" FontSize="13"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FDE68A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- 결과 목록 -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="검색 결과"
                           FontWeight="Bold" FontSize="13" Margin="0,0,0,8"/>

                <!-- 로딩 인디케이터 (애니메이션) -->
                <StackPanel Grid.Row="1" HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLoading,
                                Converter={StaticResource BoolToVisibility}}">

                    <!-- 회전 스피너 -->
                    <Grid Width="40" Height="40" Margin="0,0,0,12">
                        <Ellipse Width="40" Height="40"
                                 Stroke="#E0E0E0" StrokeThickness="4"/>
                        <Path x:Name="SpinnerArc"
                              Stroke="#0078D4" StrokeThickness="4"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                              RenderTransformOrigin="0.5,0.5">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="20,2">
                                        <ArcSegment Point="38,20" Size="18,18"
                                                    SweepDirection="Clockwise" IsLargeArc="False"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.RenderTransform>
                                <RotateTransform x:Name="SpinnerRotate" Angle="0"/>
                            </Path.RenderTransform>
                        </Path>
                    </Grid>

                    <!-- 텍스트 (점 깜빡임) -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="검색 중" FontSize="14" Foreground="#555"/>
                        <TextBlock x:Name="Dot1" Text="." FontSize="14" Foreground="#555" Opacity="0"/>
                        <TextBlock x:Name="Dot2" Text="." FontSize="14" Foreground="#555" Opacity="0"/>
                        <TextBlock x:Name="Dot3" Text="." FontSize="14" Foreground="#555" Opacity="0"/>
                    </StackPanel>

                    <StackPanel.Triggers>
                        <EventTrigger RoutedEvent="FrameworkElement.Loaded">
                            <BeginStoryboard>
                                <Storyboard RepeatBehavior="Forever">
                                    <!-- 스피너 회전 -->
                                    <DoubleAnimation
                                        Storyboard.TargetName="SpinnerRotate"
                                        Storyboard.TargetProperty="Angle"
                                        From="0" To="360" Duration="0:0:0.9"/>

                                    <!-- 점 1 -->
                                    <DoubleAnimation
                                        Storyboard.TargetName="Dot1"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1" Duration="0:0:0.2"
                                        BeginTime="0:0:0"/>
                                    <!-- 점 2 -->
                                    <DoubleAnimation
                                        Storyboard.TargetName="Dot2"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1" Duration="0:0:0.2"
                                        BeginTime="0:0:0.3"/>
                                    <!-- 점 3 -->
                                    <DoubleAnimation
                                        Storyboard.TargetName="Dot3"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1" Duration="0:0:0.2"
                                        BeginTime="0:0:0.6"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </StackPanel.Triggers>
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SearchResults}"
                          SelectedItem="{Binding SelectedItem}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          BorderThickness="0"
                          RowBackground="White"
                          AlternatingRowBackground="#F8F9FA"
                          FontSize="12"
                          Visibility="{Binding IsLoading,
                              Converter={StaticResource InvertBoolToVisibility}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="기관명" Binding="{Binding Name}"
                                            Width="180" MinWidth="120"/>
                        <DataGridTextColumn Header="요양기관코드" Binding="{Binding InstitutionCode}"
                                            Width="120"/>
                        <DataGridTextColumn Header="사업자번호" Binding="{Binding BusinessNumber}"
                                            Width="110"
                                            Foreground="#888888"/>
                        <DataGridTextColumn Header="주소" Binding="{Binding Address}"
                                            Width="*" MinWidth="180"/>
                        <DataGridTextColumn Header="우편번호" Binding="{Binding PostalCode}"
                                            Width="75"/>
                        <DataGridTextColumn Header="종별" Binding="{Binding InstitutionType}"
                                            Width="90"/>
                        <DataGridTextColumn Header="전화번호" Binding="{Binding PhoneNumber}"
                                            Width="110"/>
                        <DataGridTextColumn Header="출처" Binding="{Binding DataSource}"
                                            Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- 선택 항목 상세 -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Margin="0,0,0,12"
                Visibility="{Binding SelectedItem,
                    Converter={StaticResource NullToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock FontWeight="Bold" FontSize="13" Margin="0,0,0,6"
                               Text="{Binding SelectedItem.Name,
                                   StringFormat='📋 {0}'}"/>
                    <WrapPanel Margin="0,0,0,6">
                        <TextBlock FontSize="12" Foreground="#444"
                                   Text="{Binding SelectedItem.InstitutionCode,
                                       StringFormat='요양기관코드: {0}'}"/>
                        <TextBlock FontSize="12" Foreground="#888" Margin="16,0">|</TextBlock>
                        <TextBlock FontSize="12" Foreground="#444"
                                   Text="{Binding SelectedItem.Address,
                                       StringFormat='주소: {0}'}"/>
                        <TextBlock FontSize="12" Foreground="#888" Margin="16,0">|</TextBlock>
                        <TextBlock FontSize="12" Foreground="#444"
                                   Text="{Binding SelectedItem.PostalCode,
                                       StringFormat='우편번호: {0}'}"/>
                    </WrapPanel>
                    <!-- 사업자번호 직접 입력 -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="사업자번호:" FontSize="12" Foreground="#444"
                                   VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBox x:Name="BizNoInput"
                                 Text="{Binding SelectedBizNo, UpdateSourceTrigger=PropertyChanged}"
                                 FontSize="12" Width="140" Padding="4,3"
                                 BorderBrush="#CCCCCC" VerticalContentAlignment="Center"
                                 MaxLength="12">
                            <TextBox.Style>
                                <Style TargetType="TextBox">
                                    <Style.Triggers>
                                        <Trigger Property="Text" Value="">
                                            <Setter Property="Background">
                                                <Setter.Value>
                                                    <VisualBrush Stretch="None" AlignmentX="Left">
                                                        <VisualBrush.Visual>
                                                            <TextBlock Text="000-00-00000"
                                                                       Foreground="#BBBBBB" FontSize="12"
                                                                       Margin="5,0,0,0"/>
                                                        </VisualBrush.Visual>
                                                    </VisualBrush>
                                                </Setter.Value>
                                            </Setter>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBox.Style>
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return"
                                            Command="{Binding SaveBizNoCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Content="저장" Command="{Binding SaveBizNoCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="10,4" FontSize="11" Margin="6,0,0,0"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Top">
                    <Button Content="코드 복사" Command="{Binding CopyInstitutionCodeCommand}"
                            Style="{StaticResource PrimaryButton}"
                            Padding="12,6" FontSize="12" Margin="0,0,8,0"/>
                    <Button Content="주소 복사" Command="{Binding CopyAddressCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="12,6" FontSize="12"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 상태바 -->
        <Border Grid.Row="5" Background="#E8E8E8" CornerRadius="4" Padding="12,6">
            <TextBlock Text="{Binding StatusMessage}" FontSize="12" Foreground="#555"/>
        </Border>
    </Grid>
</Window>
