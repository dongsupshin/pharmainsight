<Window x:Class="MedSearchApp.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="API 키 설정" Height="600" Width="600"
        MinHeight="560" MinWidth="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="#F5F5F5">

    <Window.Resources>
        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,9"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#006BBF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#CCCCCC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButton" TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
            <Setter Property="Background" Value="#6C757D"/>
        </Style>

        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#0078D4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="1" Color="#CCCCCC" Opacity="0.4"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Consolas"/>
        </Style>

        <Style x:Key="BadgeRed" TargetType="Border">
            <Setter Property="Background" Value="#FFF3CD"/>
            <Setter Property="BorderBrush" Value="#FFCA2C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>

        <Style x:Key="BadgeGreen" TargetType="Border">
            <Setter Property="Background" Value="#D1E7DD"/>
            <Setter Property="BorderBrush" Value="#198754"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 헤더 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="설정" FontSize="18" FontWeight="Bold" Foreground="#1A1A2E"/>
            <TextBlock Text="검색 서비스 이용을 위해 데이터 파일과 API 키를 설정해주세요."
                       FontSize="12" Foreground="#666" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 카드 영역 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- 사업자번호 데이터 (ZIP/XLSX/CSV) -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="① 사업자번호 데이터  — 1순위"
                                           FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="건강보험심사평가원 전국 병의원 및 약국 현황 (ZIP/XLSX)"
                                           FontSize="11" Foreground="#666" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" x:Name="DataBadge"
                                    Style="{StaticResource BadgeRed}" VerticalAlignment="Center">
                                <TextBlock x:Name="DataBadgeText" Text="미설치"
                                           FontSize="11" Foreground="#856404"/>
                            </Border>
                        </Grid>

                        <!-- 데이터 상태 표시 -->
                        <TextBlock x:Name="DataStatusText"
                                   Text="데이터 파일이 없습니다. 아래 버튼으로 다운로드 후 파일을 선택해주세요."
                                   FontSize="11" Foreground="#888" Margin="0,0,0,8"
                                   TextWrapping="Wrap"/>

                        <!-- 다운로드 + 파일 선택 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Button Content="다운로드 페이지 (HIRA)"
                                    Style="{StaticResource LinkButton}"
                                    Click="OpenHiraDownloadPage_Click"
                                    Margin="0,0,16,0"/>
                            <Button Content="파일 선택 (ZIP/XLSX/CSV)..."
                                    Style="{StaticResource LinkButton}"
                                    Click="PickDataFile_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- HIRA API -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="② 건강보험심사평가원 (HIRA) API  — 2순위"
                                           FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="병원/약국 실시간 검색 (사업자번호 미포함)"
                                           FontSize="11" Foreground="#666" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" x:Name="HiraBadge"
                                    Style="{StaticResource BadgeRed}" VerticalAlignment="Center">
                                <TextBlock x:Name="HiraBadgeText" Text="키 없음"
                                           FontSize="11" Foreground="#856404"/>
                            </Border>
                        </Grid>

                        <TextBlock Style="{StaticResource Label}" Text="인증키"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                <TextBox x:Name="HiraKeyBox"
                                         Style="{StaticResource InputBox}"/>
                                <TextBlock Text="공공데이터포털에서 발급받은 인증키 입력"
                                           Foreground="#AAAAAA" FontSize="12"
                                           Margin="12,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Focusable="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=HiraKeyBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="1" Content="발급 페이지"
                                    Style="{StaticResource LinkButton}"
                                    Click="OpenHiraPage_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Bizno API (사업자번호 자동 조회) -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="③ 사업자번호 자동 조회 (bizno.net / 머니핀)"
                                           FontWeight="Bold" FontSize="13"/>
                                <TextBlock Text="상호명으로 사업자등록번호 자동 매칭 (무료 200건/일)"
                                           FontSize="11" Foreground="#666" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" x:Name="BiznoBadge"
                                    Style="{StaticResource BadgeRed}" VerticalAlignment="Center">
                                <TextBlock x:Name="BiznoBadgeText" Text="키 없음"
                                           FontSize="11" Foreground="#856404"/>
                            </Border>
                        </Grid>

                        <TextBlock Style="{StaticResource Label}" Text="API 키"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Margin="0,0,8,0">
                                <TextBox x:Name="BiznoKeyBox"
                                         Style="{StaticResource InputBox}"/>
                                <TextBlock Text="bizno.net에서 발급받은 API 키 입력"
                                           Foreground="#AAAAAA" FontSize="12"
                                           Margin="12,0,0,0" VerticalAlignment="Center"
                                           IsHitTestVisible="False" Focusable="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text, ElementName=BiznoKeyBox}" Value="">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                            <Button Grid.Column="1" Content="가입 페이지"
                                    Style="{StaticResource LinkButton}"
                                    Click="OpenBiznoPage_Click"
                                    VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="검색 후 사업자번호를 자동으로 채웁니다. 키가 없어도 수동 입력은 가능합니다."
                                   FontSize="11" Foreground="#888" Margin="0,6,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 하단 버튼 -->
        <Grid Grid.Row="2" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="저장하면 appsettings.json에 기록됩니다."
                       FontSize="11" Foreground="#999" VerticalAlignment="Center"/>

            <Button Grid.Column="1" Content="취소"
                    Style="{StaticResource SecondaryButton}"
                    Margin="0,0,8,0"
                    Click="Cancel_Click"/>

            <Button Grid.Column="2" Content="저장"
                    Style="{StaticResource PrimaryButton}"
                    Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>
