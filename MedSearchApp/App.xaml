<Application x:Class="MedSearchApp.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MedSearchApp.Converters"
             Startup="Application_Startup">
    <Application.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
        <conv:InvertBoolToVisibilityConverter x:Key="InvertBoolToVisibility"/>
        <conv:NullToVisibilityConverter x:Key="NullToVisibility"/>
        <conv:MaskedIntConverter x:Key="MaskedInt"/>
    </Application.Resources>
</Application>
